# === Required ===
ALLDEBRID_KEY=your_alldebrid_api_key
DW_EMAIL=your_darkiworld_email
DW_PASSWORD=your_darkiworld_password

# === Optional: *arr integration (enables TMDB ID → title name lookup) ===
RADARR_URL=http://localhost:7878
RADARR_KEY=your_radarr_api_key
SONARR_URL=http://localhost:8989
SONARR_KEY=your_sonarr_api_key

# === Networking ===
LISTEN_PORT=8720
LISTEN_HOST=0.0.0.0
# Base URL that Radarr/Sonarr use to reach Darkiarr (for .torrent download links).
# If Radarr/Sonarr run in Docker, use the host IP instead of localhost.
# Example: http://192.168.1.100:8720
DARKIARR_BASE_URL=http://localhost:8720

# API key for Torznab authentication (Radarr/Sonarr send this with every request)
DARKIARR_API_KEY=darkiarr

# === Paths ===
# rclone WebDAV mount where AllDebrid saved links appear
MOUNT_PATH=/mnt/darkiarr/links
# Staging directory where symlinks are created for Radarr/Sonarr to import
STAGING_PATH=/mnt/darkiarr/qbit

# === Optional: DarkiWorld overrides ===
# DW_DOMAIN=darkiworld2026.com
# DW_IP=188.114.97.2
# DW_TURNSTILE_SITEKEY=0x4AAAAAAAcZdZg-G_cmB9SW
# ALLDEBRID_AGENT=darkiarr
